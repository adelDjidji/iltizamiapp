{
  "expo": {
    "name": "iltizami",
    "slug": "iltizami",
    "version": "3.0.0",
    "orientation": "portrait",
    "icon": "./assets/iltizamiIcon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "versionCode":3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF00"
      },
      "permissions":[],
      "package": "com.djidjikdadi.iltizamiapp"
    },
    "web": {
      "favicon": "./assets/iltizamiIcon.png"
    },
    "plugins": [
      "sentry-expo"
    ],
    "hooks": {
      "postPublish": [
        {
          "file": "sentry-expo/upload-sourcemaps",
          "config": {
            "organization": "adel-tech",
            "project": "iltizami",
            "authToken": "9c59ef07e9dd4b60bc1ac50da02fd59682a0c4d1f89840998ddfdf4413cbf284"
          }
        }
      ]
    }
  }
}
