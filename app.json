{
  "expo": {
    "name": "iltizami",
    "slug": "iltizami",
    "version": "3.0.0",
    "orientation": "portrait",
    "icon": "./assets/iltizamiIcon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "versionCode":4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF00"
      },
      "permissions": ["android.permission.RECEIVE_BOOT_COMPLETED", "android.permission.POST_NOTIFICATIONS"],
      "package": "com.djidjikdadi.iltizamiapp"
    },
    "web": {
      "favicon": "./assets/iltizamiIcon.png"
    },
    "plugins": [
      [
        "@sentry/react-native/expo",
        {
          "organization": "adel-tech",
          "project": "iltizami"
        }
      ]
    ]
  }
}
