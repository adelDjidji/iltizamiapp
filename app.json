{
  "expo": {
    "name": "iltizami",
    "slug": "iltizami",
    "version": "3.1.0",
    "orientation": "portrait",
    "icon": "./assets/iltizamiIcon.png",
    "updates": {
      "url": "https://u.expo.dev/0223f06c-c383-4c15-8ddc-aba1cffd817e",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "0223f06c-c383-4c15-8ddc-aba1cffd817e"
      }
    },
    "assetBundlePatterns": [
      "assets/**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.djidjikdadi.iltizami",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 5,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF00"
      },
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "package": "com.djidjikdadi.iltizami"
    },
    "web": {
      "favicon": "./assets/iltizamiIcon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "cover",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1A1A2E",
          "defaultChannel": "prayer-reminders",
          "sounds": []
        }
      ]
    ],
    "owner": "djidjikdadi"
  }
}
