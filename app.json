{
  "expo": {
    "name": "iltizamiapp",
    "slug": "iltizamiapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/iltizamiIcon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/iltizamiIcon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.djidjikdadi.iltizamiapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
