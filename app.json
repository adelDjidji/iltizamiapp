{
  "expo": {
    "name": "iltizami",
    "slug": "iltizami",
    "version": "3.0.0",
    "orientation": "portrait",
    "icon": "./assets/iltizamiIcon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "url": "https://u.expo.dev/0223f06c-c383-4c15-8ddc-aba1cffd817e",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "0223f06c-c383-4c15-8ddc-aba1cffd817e"
      }
    },
    "assetBundlePatterns": ["assets/**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.djidjikdadi.iltizamiapp"
    },
    "android": {
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF00"
      },
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "package": "com.djidjikdadi.iltizamiapp"
    },
    "web": {
      "favicon": "./assets/iltizamiIcon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1A1A2E",
          "defaultChannel": "prayer-reminders",
          "sounds": []
        }
      ],
      // [
      //   "@sentry/react-native/expo",
      //   {
      //     "organization": "adel-dev",
      //     "project": "iltizami"
      //   }
      // ]
    ],
    "owner": "djidjikdadi"
  }
}
